# ─── Core ───────────────────────────────────────────────────────────────────
# Genera con: openssl rand -base64 32
AUTH_SECRET=

# URL base. Local: http://localhost:3000  · Railway: https://<service>.up.railway.app
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database (Postgres) ────────────────────────────────────────────────────
# Local con docker compose:  postgres://slidespro:slidespro@localhost:5434/slidespro
# Railway: la inyecta automáticamente como DATABASE_URL
DATABASE_URL=postgres://slidespro:slidespro@localhost:5434/slidespro

# ─── Auth providers ─────────────────────────────────────────────────────────
# Google OAuth (https://console.cloud.google.com)
# Authorized redirect URIs: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (opcional)
# https://github.com/settings/developers — Authorization callback URL: <NEXTAUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email magic links via Resend (https://resend.com/api-keys)
RESEND_API_KEY=
EMAIL_FROM="SlidesPro <no-reply@slidespro.app>"

# ─── AI providers (servidor, no se exponen al cliente) ──────────────────────
# Gemini — https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI (opcional, fallback) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Storage (Cloudflare R2 — S3 compatible) ────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=slidespro-assets
R2_PUBLIC_URL=https://assets.slidespro.app

# ─── Queue (Redis) ──────────────────────────────────────────────────────────
# Local con docker compose: redis://localhost:6380
# Railway: variable REDIS_URL la expone el plugin Redis
REDIS_URL=redis://localhost:6380

# ─── Observabilidad ─────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── Stripe (Fase 8) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_TEAM_MONTHLY=
