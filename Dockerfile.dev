# Dev container con hot reload. Usado por docker-compose.yml.
# Las dependencias se instalan en una capa separada para aprovechar caché.

FROM node:22-alpine

RUN apk add --no-cache libc6-compat openssl bash
WORKDIR /app

# Layer 1: deps (cacheado mientras package*.json no cambien)
COPY package.json package-lock.json* ./
COPY prisma ./prisma
RUN npm ci --no-audit --no-fund

# Layer 2: source (montado como volume en compose; aquí solo para imagen base)
COPY . .

ENV NEXT_TELEMETRY_DISABLED=1
ENV HOSTNAME=0.0.0.0
ENV PORT=3000
EXPOSE 3000

# El comando real lo define docker-compose.yml (corre migraciones + dev server).
CMD ["npm", "run", "dev"]
