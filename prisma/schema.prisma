generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth (Auth.js / NextAuth v5 — PrismaAdapter shape)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  workspaces    WorkspaceMember[]
  presentations Presentation[]
  aiUsage       AIUsage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────────────
// Workspaces (multi-tenant; user can belong to multiple)
// ─────────────────────────────────────────────────────────────────────────────

enum WorkspaceRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       WorkspaceMember[]
  presentations Presentation[]
  themes        Theme[]
  subscription  Subscription?
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(EDITOR)
  joinedAt    DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Presentations (slides stored as JSON conforming to Slide Schema)
// ─────────────────────────────────────────────────────────────────────────────

enum PresentationStatus {
  DRAFT
  GENERATING
  READY
  ERROR
}

model Presentation {
  id          String             @id @default(cuid())
  workspaceId String
  ownerId     String
  title       String
  description String?
  status      PresentationStatus @default(DRAFT)
  themeId     String?
  // Source brief/inputs that produced the deck (transcript, URL, files, options)
  sourceBrief Json?
  // Optional cover image asset (R2 URL)
  coverUrl    String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  theme     Theme?     @relation(fields: [themeId], references: [id])
  slides    Slide[]
  versions  PresentationVersion[]
  jobs      GenerationJob[]
  assets    Asset[]

  @@index([workspaceId])
  @@index([ownerId])
}

// One row per slide. `data` is the Slide Schema JSON (zod-validated in app).
model Slide {
  id             String   @id @default(cuid())
  presentationId String
  position       Int
  data           Json
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  presentation Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)

  @@unique([presentationId, position])
  @@index([presentationId])
}

// Snapshot of a whole deck for undo/restore (used by AI refinement, "version history")
model PresentationVersion {
  id             String   @id @default(cuid())
  presentationId String
  label          String?
  // Full snapshot: { title, themeId, slides: [...] }
  snapshot       Json
  createdAt      DateTime @default(now())
  createdBy      String?

  presentation Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)

  @@index([presentationId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Themes (5 archetypes ported from legacy + custom user themes)
// ─────────────────────────────────────────────────────────────────────────────

model Theme {
  id          String   @id @default(cuid())
  workspaceId String?  // null = global/preset theme
  name        String
  slug        String   @unique
  isPreset    Boolean  @default(false)
  // Theme tokens (palette, typography, spacing) — see lib/schema/theme.ts
  tokens      Json
  preview     String?  // URL to preview image
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  presentations Presentation[]

  @@index([workspaceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Assets (images generated by IA, uploads, exports) stored on R2
// ─────────────────────────────────────────────────────────────────────────────

enum AssetKind {
  AI_IMAGE
  UPLOAD
  EXPORT_PPTX
  EXPORT_PDF
  EXPORT_HTML
  THUMBNAIL
}

model Asset {
  id             String    @id @default(cuid())
  presentationId String?
  workspaceId    String?
  kind           AssetKind
  url            String    // R2 public URL
  key            String    // R2 object key
  contentType    String
  size           Int
  width          Int?
  height         Int?
  prompt         String?   // for AI_IMAGE: the prompt used
  metadata       Json?
  createdAt      DateTime  @default(now())

  presentation Presentation? @relation(fields: [presentationId], references: [id], onDelete: Cascade)

  @@index([presentationId])
  @@index([workspaceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Generation jobs (BullMQ-backed long-running tasks)
// ─────────────────────────────────────────────────────────────────────────────

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum JobKind {
  GENERATE_PRESENTATION
  GENERATE_IMAGES
  REFINE_PRESENTATION
  REGENERATE_SLIDE
  EXPORT
  INGEST_DOCUMENT
}

model GenerationJob {
  id             String    @id @default(cuid())
  presentationId String?
  kind           JobKind
  status         JobStatus @default(PENDING)
  progress       Int       @default(0) // 0-100
  payload        Json?
  result         Json?
  error          String?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  presentation Presentation? @relation(fields: [presentationId], references: [id], onDelete: Cascade)

  @@index([presentationId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// AI usage tracking (for billing & rate limits)
// ─────────────────────────────────────────────────────────────────────────────

model AIUsage {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String?
  provider    String   // "google" | "anthropic" | "openai"
  model       String
  kind        String   // "text" | "image" | "audio"
  inputTokens Int      @default(0)
  outputTokens Int     @default(0)
  imageCount  Int      @default(0)
  costUsd     Decimal  @default(0) @db.Decimal(10, 6)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Billing (Stripe)
// ─────────────────────────────────────────────────────────────────────────────

enum SubscriptionTier {
  FREE
  PRO
  TEAM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

model Subscription {
  id                     String             @id @default(cuid())
  workspaceId            String             @unique
  tier                   SubscriptionTier   @default(FREE)
  status                 SubscriptionStatus @default(ACTIVE)
  stripeCustomerId       String?            @unique
  stripeSubscriptionId   String?            @unique
  stripePriceId          String?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
